PORT=8081
# Internal URL of the agents service (no /api suffix)
AGENTS_INTERNAL_URL=http://localhost:8090
DATA_DIR=../data
# USERS_DIR is optional legacy fallback only; product state is in APP_DATABASE_URL
USERS_DIR=../users
# JWT_SECRET is still used for impersonation tokens only
JWT_SECRET=changeme
# Clerk — get these from https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
LOG_LEVEL=info
TELEGRAM_SECRET=your_telegram_webhook_secret
PUBLIC_URL=https://your-domain.com
# Must match APP_DATABASE_URL in agents/.env
APP_DATABASE_URL=postgresql://user:pass@localhost:5432/startix
ADMIN_KEY=changeme-admin-key
# OpenRouter is the primary LLM gateway for the advisor chat service
OPENROUTER_API_KEY=
OBSERVABILITY_RETENTION_DAYS=14
# Idempotent schema applied once per backend start (see docs/ARCHITECTURE.md)
APP_DATABASE_DDL_PATH=../db/application_postgres.sql
# Set to 1 when running behind a reverse proxy (nginx, Caddy, etc.)
TRUST_PROXY=1
